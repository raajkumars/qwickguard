[Unit]
Description=QwickGuard Agent - Infrastructure monitoring and guard service
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=__VENV_PATH__/bin/qwickguard-agent
Environment=QWICKGUARD_CONFIG=__CONFIG_PATH__
Environment=PATH=__VENV_PATH__/bin:/usr/local/bin:/usr/bin:/bin
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
